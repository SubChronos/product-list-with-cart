---
import "../styles/global.css"
interface Props {
	title: string
}
const { title } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>{title}</title>
	</head>
	<body class="bg-fm-rose-600 grid justify-center w-full min-h-screen m-0">
		<slot />
	</body>
</html>
